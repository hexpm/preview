<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={assigns[:meta_description] || "Web based preview of Hex packages"}
    />
    <%= if assigns[:canonical] do %>
      <link rel="canonical" href={assigns[:canonical]} />
    <% end %>
    {csrf_meta_tag()}
    <.live_title suffix=" | hexpreview">
      {assigns[:page_title] || "Home"}
    </.live_title>

    <%!-- Intentional duplication of the theme resolution logic from assets/js/theme.js.
          This inline script runs synchronously before any stylesheet or JS bundle is parsed,
          which prevents a flash of unstyled/wrong-theme content (FOUC).
          If you change the key name, attribute names, or resolution logic in theme.js,
          update this script to match. --%>
    <script>
      (() => {
        const key = "hexpm-theme";
        let stored = null;
        try { stored = localStorage.getItem(key); } catch (_e) {}
        const sys = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        const pref = stored === "light" || stored === "dark" ? stored : "system";
        const theme = pref === "system" ? sys : pref;
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.setAttribute("data-theme-preference", pref);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>

    <link rel="icon" type="image/svg+xml" href={~p"/images/hex-full.svg"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>

    <%= if host = Application.get_env(:preview, :host) do %>
      <script async defer src={"https://s.#{host}/js/script.js"}>
      </script>
      <script>
        window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init({endpoint:"https://s.<%= host %>/api/event"})
      </script>
    <% end %>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
